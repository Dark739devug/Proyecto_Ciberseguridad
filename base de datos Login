--creacion de la abse de datoscreate database DBFactur--ahora par usaralause DBFactur -- Crear tabla de usuariosCREATE TABLE Usuario (    id_usuario SERIAL PRIMARY KEY,    nombre VARCHAR(100) NOT NULL,    apellido VARCHAR(100) NOT NULL,    fecha_nacimiento DATE NOT NULL,    nit VARCHAR(20) UNIQUE NOT NULL,    dpi VARCHAR(20) UNIQUE NOT NULL);-- Crear tabla de loginCREATE TABLE Login (    id_login SERIAL PRIMARY KEY,    correo_electronico VARCHAR(150) UNIQUE NOT NULL,    contrasena VARCHAR(255) NOT NULL,    id_usuario INT NOT NULL,    FOREIGN KEY (id_usuario) REFERENCES Usuario(id_usuario) ON DELETE CASCADE);select * from Usuario