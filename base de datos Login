-- ============================================
-- TABLAS BASE
-- ============================================

CREATE TABLE roles (
    id_rol SERIAL PRIMARY KEY,
    nombre_rol VARCHAR(50) NOT NULL UNIQUE,
    descripcion TEXT,
    fecha_creacion TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    activo BOOLEAN DEFAULT TRUE
);

CREATE TABLE usuarios (
    id_usuario SERIAL PRIMARY KEY,
    nombre VARCHAR(200) NOT NULL,
    apellido VARCHAR(100) NOT NULL,
    email VARCHAR(150) NOT NULL UNIQUE,
    id_rol INTEGER NOT NULL,
    activo BOOLEAN DEFAULT TRUE,
    FOREIGN KEY (id_rol) REFERENCES roles(id_rol)
);

-- 🔐 Tabla de login separada
CREATE TABLE login_usuarios (
    id_login SERIAL PRIMARY KEY,
    id_usuario INTEGER NOT NULL UNIQUE,
    email VARCHAR(150) NOT NULL UNIQUE,
    password_hash VARCHAR(255) NOT NULL,
    ultimo_login TIMESTAMP,
    fecha_creacion TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (id_usuario) REFERENCES usuarios(id_usuario) ON DELETE CASCADE
);

CREATE TABLE establecimientos (
    id_establecimiento SERIAL PRIMARY KEY,
    nit VARCHAR(20) NOT NULL UNIQUE,
    nombre_comercial VARCHAR(200) NOT NULL,
    razon_social VARCHAR(200) NOT NULL,
    direccion TEXT NOT NULL,
    municipio VARCHAR(100),
    departamento VARCHAR(100),
    codigo_postal VARCHAR(10),
    telefono VARCHAR(20),
    email VARCHAR(150),
    codigo_establecimiento VARCHAR(10) UNIQUE,
    activo_certificador BOOLEAN DEFAULT TRUE,
    fecha_registro TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    activo BOOLEAN DEFAULT TRUE
);

CREATE TABLE clientes (
    id_cliente SERIAL PRIMARY KEY,
    nit VARCHAR(20) NOT NULL,
    razon_social VARCHAR(200) NOT NULL,
    nombre_comercial VARCHAR(200),
    direccion TEXT NOT NULL,
    municipio VARCHAR(100),
    departamento VARCHAR(100),
    telefono VARCHAR(20),
    email VARCHAR(150),
    fecha_registro TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    activo BOOLEAN DEFAULT TRUE,
    CONSTRAINT unique_nit_cliente UNIQUE (nit)
);

CREATE TABLE categorias_productos (
    id_categoria SERIAL PRIMARY KEY,
    nombre_categoria VARCHAR(100) NOT NULL UNIQUE,
    descripcion TEXT,
    activo BOOLEAN DEFAULT TRUE
);

CREATE TABLE productos (
    id_producto SERIAL PRIMARY KEY,
    codigo_producto VARCHAR(50) NOT NULL UNIQUE,
    nombre_producto VARCHAR(200) NOT NULL,
    descripcion TEXT,
    id_categoria INTEGER,
    id_establecimiento INTEGER,
    precio_unitario NUMERIC(12, 2) NOT NULL CHECK (precio_unitario >= 0),
    stock_actual INTEGER DEFAULT 0 CHECK (stock_actual >= 0),
    unidad_medida VARCHAR(20) DEFAULT 'UNIDAD',
    aplica_iva BOOLEAN DEFAULT TRUE,
    fecha_creacion TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    activo BOOLEAN DEFAULT TRUE,
    FOREIGN KEY (id_categoria) REFERENCES categorias_productos(id_categoria),
    FOREIGN KEY (id_establecimiento) REFERENCES establecimientos(id_establecimiento)
);

CREATE TABLE tipos_documento (
    id_tipo_documento SERIAL PRIMARY KEY,
    codigo_tipo VARCHAR(10) NOT NULL UNIQUE,
    nombre_tipo VARCHAR(100) NOT NULL,
    descripcion TEXT,
    activo BOOLEAN DEFAULT TRUE
);

CREATE TABLE estados_factura (
    id_estado SERIAL PRIMARY KEY,
    codigo_estado VARCHAR(20) NOT NULL UNIQUE,
    nombre_estado VARCHAR(50) NOT NULL,
    descripcion TEXT
);

CREATE TABLE facturas (
    id_factura SERIAL PRIMARY KEY,
    numero_factura VARCHAR(50) UNIQUE,
    serie VARCHAR(20),
    correlativo INTEGER,
    numero_autorizacion VARCHAR(100) UNIQUE,
    id_establecimiento INTEGER NOT NULL,
    id_cliente INTEGER NOT NULL,
    id_tipo_documento INTEGER NOT NULL,
    fecha_emision TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    fecha_certificacion TIMESTAMP,
    subtotal NUMERIC(12, 2) NOT NULL CHECK (subtotal >= 0),
    total_descuentos NUMERIC(12, 2) DEFAULT 0 CHECK (total_descuentos >= 0),
    subtotal_con_descuento NUMERIC(12, 2) NOT NULL CHECK (subtotal_con_descuento >= 0),
    total_iva NUMERIC(12, 2) NOT NULL CHECK (total_iva >= 0),
    total_factura NUMERIC(12, 2) NOT NULL CHECK (total_factura >= 0),
    id_estado INTEGER NOT NULL,
    id_usuario_creacion INTEGER NOT NULL,
    observaciones TEXT,
    uuid_certificacion VARCHAR(100),
    xml_certificado TEXT,
    fecha_anulacion TIMESTAMP,
    motivo_anulacion TEXT,
    id_usuario_anulacion INTEGER,
    FOREIGN KEY (id_establecimiento) REFERENCES establecimientos(id_establecimiento),
    FOREIGN KEY (id_cliente) REFERENCES clientes(id_cliente),
    FOREIGN KEY (id_tipo_documento) REFERENCES tipos_documento(id_tipo_documento),
    FOREIGN KEY (id_estado) REFERENCES estados_factura(id_estado),
    FOREIGN KEY (id_usuario_creacion) REFERENCES usuarios(id_usuario),
    FOREIGN KEY (id_usuario_anulacion) REFERENCES usuarios(id_usuario)
);

CREATE TABLE detalle_facturas (
    id_detalle SERIAL PRIMARY KEY,
    id_factura INTEGER NOT NULL,
    numero_linea INTEGER NOT NULL,
    id_producto INTEGER NOT NULL,
    descripcion_producto VARCHAR(500) NOT NULL,
    cantidad NUMERIC(10, 2) NOT NULL CHECK (cantidad > 0),
    unidad_medida VARCHAR(20) NOT NULL,
    precio_unitario NUMERIC(12, 2) NOT NULL CHECK (precio_unitario >= 0),
    descuento NUMERIC(12, 2) DEFAULT 0 CHECK (descuento >= 0),
    subtotal_linea NUMERIC(12, 2) NOT NULL CHECK (subtotal_linea >= 0),
    aplica_iva BOOLEAN DEFAULT TRUE,
    monto_iva NUMERIC(12, 2) DEFAULT 0 CHECK (monto_iva >= 0),
    total_linea NUMERIC(12, 2) NOT NULL CHECK (total_linea >= 0),
    FOREIGN KEY (id_factura) REFERENCES facturas(id_factura) ON DELETE CASCADE,
    FOREIGN KEY (id_producto) REFERENCES productos(id_producto),
    CONSTRAINT unique_linea_factura UNIQUE (id_factura, numero_linea)
);

CREATE TABLE bitacora_certificacion (
    id_bitacora SERIAL PRIMARY KEY,
    id_factura INTEGER NOT NULL,
    fecha_intento TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    exitoso BOOLEAN NOT NULL,
    codigo_respuesta VARCHAR(20),
    mensaje_respuesta TEXT,
    datos_enviados JSONB,
    datos_recibidos JSONB,
    usuario_responsable INTEGER,
    FOREIGN KEY (id_factura) REFERENCES facturas(id_factura),
    FOREIGN KEY (usuario_responsable) REFERENCES usuarios(id_usuario)
);

CREATE TABLE configuracion_sistema (
    id_configuracion SERIAL PRIMARY KEY,
    clave VARCHAR(100) NOT NULL UNIQUE,
    valor TEXT NOT NULL,
    descripcion TEXT,
    tipo_dato VARCHAR(20) DEFAULT 'STRING',
    fecha_modificacion TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE auditoria (
    id_auditoria SERIAL PRIMARY KEY,
    id_usuario INTEGER,
    accion VARCHAR(100) NOT NULL,
    tabla_afectada VARCHAR(100),
    id_registro INTEGER,
    datos_anteriores JSONB,
    datos_nuevos JSONB,
    ip_address VARCHAR(50),
    fecha_accion TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (id_usuario) REFERENCES usuarios(id_usuario)
);

-- ============================================
-- ÍNDICES
-- ============================================

CREATE INDEX idx_usuarios_email ON usuarios(email);
CREATE INDEX idx_usuarios_rol ON usuarios(id_rol);
CREATE INDEX idx_clientes_nit ON clientes(nit);
CREATE INDEX idx_clientes_razon_social ON clientes(razon_social);
CREATE INDEX idx_productos_codigo ON productos(codigo_producto);
CREATE INDEX idx_productos_categoria ON productos(id_categoria);
CREATE INDEX idx_productos_activo ON productos(activo);
CREATE INDEX idx_facturas_numero ON facturas(numero_factura);
CREATE INDEX idx_facturas_estado ON facturas(id_estado);
CREATE INDEX idx_facturas_fecha_emision ON facturas(fecha_emision);
CREATE INDEX idx_bitacora_factura ON bitacora_certificacion(id_factura);
CREATE INDEX idx_auditoria_usuario ON auditoria(id_usuario);

