-- ============================================
-- FUNCIONES Y TRIGGERS
-- ============================================

CREATE OR REPLACE FUNCTION actualizar_stock_producto()
RETURNS TRIGGER AS $$
BEGIN
    IF TG_OP = 'INSERT' THEN
        UPDATE productos 
        SET stock_actual = stock_actual - NEW.cantidad
        WHERE id_producto = NEW.id_producto;
    ELSIF TG_OP = 'DELETE' THEN
        UPDATE productos 
        SET stock_actual = stock_actual + OLD.cantidad
        WHERE id_producto = OLD.id_producto;
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trigger_actualizar_stock
AFTER INSERT OR DELETE ON detalle_facturas
FOR EACH ROW
EXECUTE FUNCTION actualizar_stock_producto();

CREATE OR REPLACE FUNCTION generar_numero_factura()
RETURNS TRIGGER AS $$
DECLARE
    ultimo_correlativo INTEGER;
    nueva_serie VARCHAR(20);
BEGIN
    SELECT COALESCE(MAX(correlativo), 0) INTO ultimo_correlativo
    FROM facturas
    WHERE id_establecimiento = NEW.id_establecimiento
    AND serie = TO_CHAR(CURRENT_DATE, 'YYYY');
    nueva_serie := TO_CHAR(CURRENT_DATE, 'YYYY');
    NEW.serie := nueva_serie;
    NEW.correlativo := ultimo_correlativo + 1;
    NEW.numero_factura := nueva_serie || '-' || LPAD(NEW.correlativo::TEXT, 8, '0');
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trigger_generar_numero_factura
BEFORE INSERT ON facturas
FOR EACH ROW
WHEN (NEW.numero_factura IS NULL)
EXECUTE FUNCTION generar_numero_factura();

CREATE OR REPLACE FUNCTION registrar_auditoria()
RETURNS TRIGGER AS $$
BEGIN
    IF TG_OP = 'INSERT' THEN
        INSERT INTO auditoria (id_usuario, accion, tabla_afectada, id_registro, datos_nuevos)
        VALUES (NEW.id_usuario_creacion, 'INSERT', TG_TABLE_NAME, NEW.id_factura, row_to_json(NEW));
    ELSIF TG_OP = 'UPDATE' THEN
        INSERT INTO auditoria (id_usuario, accion, tabla_afectada, id_registro, datos_anteriores, datos_nuevos)
        VALUES (NEW.id_usuario_creacion, 'UPDATE', TG_TABLE_NAME, NEW.id_factura, row_to_json(OLD), row_to_json(NEW));
    ELSIF TG_OP = 'DELETE' THEN
        INSERT INTO auditoria (id_usuario, accion, tabla_afectada, id_registro, datos_anteriores)
        VALUES (OLD.id_usuario_creacion, 'DELETE', TG_TABLE_NAME, OLD.id_factura, row_to_json(OLD));
    END IF;
    RETURN NULL;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trigger_auditoria_facturas
AFTER INSERT OR UPDATE OR DELETE ON facturas
FOR EACH ROW
EXECUTE FUNCTION registrar_auditoria();

-- ============================================
-- VISTAS
-- ============================================

CREATE OR REPLACE VIEW vista_facturas_completas AS
SELECT 
    f.id_factura,
    f.numero_factura,
    f.serie,
    f.correlativo,
    f.numero_autorizacion,
    f.fecha_emision,
    f.fecha_certificacion,
    e.nit AS establecimiento_nit,
    e.nombre_comercial AS establecimiento_nombre,
    c.nit AS cliente_nit,
    c.razon_social AS cliente_razon_social,
    c.direccion AS cliente_direccion,
    td.nombre_tipo AS tipo_documento,
    ef.nombre_estado AS estado,
    f.subtotal,
    f.total_descuentos,
    f.total_iva,
    f.total_factura,
    (u.nombre || ' ' || u.apellido) AS usuario_creacion,
    f.observaciones,
    f.fecha_anulacion,
    f.motivo_anulacion
FROM facturas f
INNER JOIN establecimientos e ON f.id_establecimiento = e.id_establecimiento
INNER JOIN clientes c ON f.id_cliente = c.id_cliente
INNER JOIN tipos_documento td ON f.id_tipo_documento = td.id_tipo_documento
INNER JOIN estados_factura ef ON f.id_estado = ef.id_estado
INNER JOIN usuarios u ON f.id_usuario_creacion = u.id_usuario;

CREATE OR REPLACE VIEW vista_productos_catalogo AS
SELECT 
    p.id_producto,
    p.codigo_producto,
    p.nombre_producto,
    p.descripcion,
    c.nombre_categoria,
    p.precio_unitario,
    p.stock_actual,
    p.unidad_medida,
    p.aplica_iva,
    p.activo
FROM productos p
LEFT JOIN categorias_productos c ON p.id_categoria = c.id_categoria;

